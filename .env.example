# ============================================================
# Local Zephr simulation
# ============================================================
# When 'true' (default in dev), src/middleware.ts fetches the real
# Finansavisen Zephr components from the URL below and splices them
# into <!-- ZEPHR_FEATURE … --> markers so you can see the FA header
# locally. In production this is left 'false' — the Zephr CDN at the
# edge handles injection.
SIMULATE_ZEPHR=true
ZEPHR_COMPONENTS_URL=https://prod-zephr-components.finansavisen.no

# ============================================================
# GitHub — for the "save" skill
# ============================================================
# Personal Access Token with repo:write on the target repo.
# Treat this like a password. Never paste it into chat or commit it.
GITHUB_PAT=
# Full HTTPS clone URL of the journalist's repo, e.g.:
# https://github.com/<org>/<repo>.git
GIT_REMOTE=

# ============================================================
# App-level vars (extend per project)
# ============================================================
# PUBLIC_… vars are exposed to the client bundle. Everything else is
# server-only. Default-port matches docker-compose / OKD service.
PORT=3000

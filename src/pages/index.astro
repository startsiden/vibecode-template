---
import Base from '../layouts/Base.astro';
---
<Base title="Finansavisen Vibe Starter" showFaChrome={false}>
  <section class="mx-auto max-w-2xl px-6 py-16">
    <p class="mb-2 text-sm font-medium uppercase tracking-wide text-blue-500">
      Finansavisen
    </p>
    <h1 class="mb-4 text-4xl font-semibold text-gray-900">
      Hello from your new app.
    </h1>
    <p class="text-lg text-gray-600">
      Edit <code class="rounded bg-gray-50 px-1.5 py-0.5 text-sm">src/pages/index.astro</code>
      to start. Ask your agent for help — say things like
      <em>"add an about page"</em> or <em>"make the heading red"</em>.
    </p>
  </section>
</Base>
